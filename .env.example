# 通用LLM配置（支持OpenAI兼容API）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# DeepSeek API配置（向后兼容）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 本地客户端用户ID（用于local_client.py）
LOCAL_USER_ID=your_custom_name_here

# 指定LLM可以访问的根目录，默认为"brain"
LLM_ROOT_DIRECTORY=brain

# 会话保存配置
SESSION_SAVE_DIR=./brain/session  # 会话保存目录，默认为LLM_ROOT_DIRECTORY/session

# 企业微信配置（从legacy/.env复制）
WECHAT_WORK_CORPID=your_corpid_here
WECHAT_WORK_CORPSECRET=your_corpsecret_here
WECHAT_WORK_AGENTID=yout_agentid_here
WECHAT_WORK_CALLBACK_TOKEN=your_token_here
WECHAT_WORK_ENCODING_AES_KEY=your_aes_key_here

# 日志配置
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_TO_CONSOLE=true
LOG_DIR=./logs
MAX_LOG_FILE_SIZE=10485760
LOG_BACKUP_COUNT=5

# 消息处理配置
MESSAGE_BATCH_TIMEOUT=40  # 秒，批量处理超时时间
CONVERSATION_TIMEOUT=3600  # 秒，对话超时时间（60分钟）
MAX_USERS=10  # 最大用户数

# 对话历史配置
ENABLE_CONVERSATION_HISTORY=true  # 是否启用对话历史功能
MAX_HISTORY_LENGTH=20  # 最大历史消息数
MAX_CONTEXT_TOKENS=8000  # 最大上下文token数

# Jina Reader API配置（用于fetch_url工具）
JINA_API_BASE=https://r.jina.ai
JINA_API_KEY=your_jina_api_key_here
